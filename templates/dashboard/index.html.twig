{% extends 'layout/base.html.twig' %}

{% block title %}Dashboard — NikanzoPHP{% endblock %}

{% block content %}
<h1 style="margin-bottom:1.5rem;font-size:1.6rem;">Dashboard</h1>

{% if is_premium %}
    <div class="alert alert-info">
        You have an active <strong>PRO</strong> subscription.
        <a href="/dashboard/advanced">Open Advanced Analytics →</a>
    </div>
{% else %}
    <div class="alert alert-warning">
        You are on the <strong>free tier</strong>.
        <a href="/upgrade">Upgrade to PRO</a> to unlock the Advanced Dashboard and more.
    </div>
{% endif %}

<div class="stat-grid">
    <div class="stat-box">
        <div class="stat-value">{{ stats.total_todos }}</div>
        <div class="stat-label">Total Todos</div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">Quick Links</span>
    </div>
    <a href="/todos" class="btn btn-outline" style="margin-right:.5rem;">View Todos</a>
    {% if is_premium %}
        <a href="/dashboard/advanced" class="btn btn-premium">Advanced Analytics</a>
    {% else %}
        <a href="/upgrade" class="btn btn-premium">Unlock Advanced Analytics</a>
    {% endif %}
</div>
{% endblock %}
